# ─── FANZA (DMM アフィリエイト API) ───────────────────────────────────────────
DMM_API_ID=your_api_id_here
DMM_AFFILIATE_ID=yourname-990

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── X (Twitter) Developer App ─────────────────────────────────────────────────
# https://developer.twitter.com で取得
# App の権限: "Read and Write" が必要
# User authentication settings: OAuth 1.0a を有効にすること
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# 自分の X アカウントの User ID（数字）
# https://tweeterid.com/ などで確認できる
TWITTER_USER_ID=123456789
